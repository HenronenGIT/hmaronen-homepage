{
  "name": "hmaronen-homepage",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.16.1",
  "scripts": {
    "dev:legacy": "pnpm --dir apps/legacy-homepage dev",
    "dev:home": "pnpm --dir apps/homepage dev",
    "build:legacy": "pnpm --dir apps/legacy-homepage build",
    "build:home": "pnpm --dir apps/homepage build",
    "check-all": "pnpm --dir apps/legacy-homepage check-all && pnpm --dir apps/homepage check-all",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prettier": "^3.6.1",
    "typescript-eslint": "^8.0.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,json,css,md,html}": [
      "prettier --write"
    ]
  }
}
