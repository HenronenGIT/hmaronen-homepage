{
  "name": "homepage",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 20",
    "format": "prettier --write \"app/**/*.{ts,tsx,js,jsx,json,css,md}\" \"*.{json,ts}\"",
    "format:check": "prettier --check \"app/**/*.{ts,tsx,js,jsx,json,css,md}\" \"*.{json,ts}\"",
    "typecheck": "tsc --noEmit",
    "check-all": "pnpm run typecheck && pnpm run lint && pnpm run format:check"
  },
  "dependencies": {
    "next": "^16.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "globals": "^15.9.0",
    "prettier": "^3.6.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.1"
  }
}
